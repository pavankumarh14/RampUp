DATABASE_URL=postgresql://user:password@localhost:5432/rampup

# LLM provider: "azure" | "openai" | "gemini"
LLM_PROVIDER=azure

# Azure OpenAI (used when LLM_PROVIDER=azure)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-api-key
AZURE_OPENAI_API_VERSION=2024-02-01
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o

# OpenAI (used when LLM_PROVIDER=openai)
OPENAI_API_KEY=your-openai-api-key
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# Gemini (uses OpenAI-compatible endpoint; used when LLM_PROVIDER=gemini)
# Note: text-embedding-004 produces 768-dim vectors. Update EMBEDDING_DIMENSION
# and run a new migration if switching from the default 3072-dim pgvector column.
GEMINI_API_KEY=your-gemini-api-key
GEMINI_CHAT_MODEL=gemini-1.5-pro
GEMINI_EMBEDDING_MODEL=text-embedding-004

# MS Graph API (for M365 ingestion)
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret

# App
APP_ENV=development
TOP_K_RESULTS=5
SIMILARITY_THRESHOLD=0.5
CHUNK_SIZE=512
CHUNK_OVERLAP=64
EMBEDDING_DIMENSION=3072
